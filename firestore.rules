rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helper Functions ────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isPolice() {
      return isAuthenticated() && getUserRole() == 'police';
    }
    
    function isHospital() {
      return isAuthenticated() && getUserRole() == 'hospital';
    }
    
    function isFire() {
      return isAuthenticated() && getUserRole() == 'fire';
    }
    
    function isDepartment() {
      return isPolice() || isHospital() || isFire() || isAdmin();
    }
    
    // ─── Users Collection ────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // ─── Complaints Collection ───────────────────────────────────
    match /complaints/{complaintId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isDepartment()
      );
      allow create: if isAuthenticated();
      allow update: if isDepartment() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // ─── Crimes Collection ───────────────────────────────────────
    match /crimes/{crimeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isPolice() || isAdmin();
      allow delete: if isAdmin();
    }
    
    // ─── Emergency Requests ──────────────────────────────────────
    match /emergency_requests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isDepartment()
      );
      allow create: if isAuthenticated();
      allow update: if isDepartment();
      allow delete: if isAdmin();
    }
    
    // ─── Alerts ──────────────────────────────────────────────────
    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isDepartment();
      allow update: if isDepartment();
      allow delete: if isAdmin();
    }
    
    // ─── Hotspots ────────────────────────────────────────────────
    match /hotspots/{hotspotId} {
      allow read: if isAuthenticated();
      allow write: if isDepartment();
    }
    
    // ─── Hospitals ───────────────────────────────────────────────
    match /hospitals/{hospitalId} {
      allow read: if isAuthenticated();
      allow write: if isHospital() || isAdmin();
    }
    
    // ─── Police Stations ─────────────────────────────────────────
    match /police_stations/{stationId} {
      allow read: if isAuthenticated();
      allow write: if isPolice() || isAdmin();
    }
    
    // ─── Fire Stations ───────────────────────────────────────────
    match /fire_stations/{stationId} {
      allow read: if isAuthenticated();
      allow write: if isFire() || isAdmin();
    }
    
    // ─── Analytics ───────────────────────────────────────────────
    match /analytics/{docId} {
      allow read: if isDepartment();
      allow write: if isAuthenticated();  // Any action can increment counters
    }
    
    // ─── Notifications ───────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ─── Response Teams ──────────────────────────────────────────
    match /response_teams/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isDepartment();
    }
    
    // ─── Citizen Reports ─────────────────────────────────────────
    match /citizen_reports/{reportId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isDepartment()
      );
      allow create: if isAuthenticated();
      allow update: if isDepartment();
      allow delete: if isAdmin();
    }
    
    // ─── Risk Zones ──────────────────────────────────────────────
    match /risk_zones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if isDepartment();
    }
  }
}
