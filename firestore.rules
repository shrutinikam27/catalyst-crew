rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── SOS Alerts ──────────────────────────────────────────────────────────
    // ANY visitor (even unauthenticated) can CREATE an SOS alert.
    // Emergency alerts must never be blocked by auth — anyone in distress
    // should be able to call for help regardless of login state.
    // Only authenticated users (volunteers) can READ or UPDATE alerts.
    match /sosAlerts/{alertId} {
      allow create: if true;                // open to all — it's an emergency
      allow read:   if request.auth != null; // volunteers must be signed in to see alerts
      allow update: if request.auth != null; // only logged-in volunteers can accept/resolve
      allow delete: if false;               // never delete; archive only
    }

    // ─── Volunteer Requests ───────────────────────────────────────────────────
    match /volunteerRequests/{docId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null && request.auth.token.email != null; // admins only in prod
      allow delete: if false;
    }

    // ─── All other collections (default deny) ─────────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
